@page
@model InventSys.Pages.Account.LoginModel

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card shadow-lg border-0 rounded-lg mt-5">
            <div class="card-header text-center">
                <h1>
                    <svg class="inventSys-logo" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20 30L50 15L80 30V70L50 85L20 70V30Z" fill="#1e88e5" />
                        <path d="M50 15L80 30L50 45L20 30L50 15Z" fill="#42a5f5" />
                        <path d="M50 45L80 30V70L50 85V45Z" fill="#0d47a1" />
                    </svg>
                    Invensys
                </h1>
             </div>
            <div class="card-body">
                <h3 class="text-center font-weight-light my-4">Inicia sesión con tu cuenta</h3>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.UserName" id="inputUsuario" class="form-control" placeholder="Usuario" />
                        <label for="inputUsuario">Usuario</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" id="inputPassword" type="password" class="form-control" placeholder="Contraseña" />
                        <label for="inputPassword">Contraseña</label>
                    </div>
                    <div class="mt-4 mb-0">
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-block">Iniciar</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>