@rendermode InteractiveServer   
@inject UsuarioUseCase usuarioUseCase

<div>
    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" OnClick="ToggleOpen" /> @userName
    <MudPopover Open="@_open" OverflowBehavior="OverflowBehavior.FlipAlways" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" RelativeWidth="DropdownWidth.Adaptive">
        <MudNavLink Icon="@Icons.Material.Filled.Settings" Href="/">Configuración</MudNavLink>
        <MudDivider Class="my-2"/>
        <MudNavLink Icon="@Icons.Material.Filled.Logout" Href="/">Cerrar Sesión</MudNavLink>
    </MudPopover>
</div>


@code {
    private bool _open = false;
    private string? userName;

    private void ToggleOpen() => _open = !_open;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            int userId = await usuarioUseCase.GetUserIdAsync();
            var user = await usuarioUseCase.ObtenerUsuarioAsync(userId);
            userName = user?.UserName ?? string.Empty;

            StateHasChanged();
        }
    }

}