@rendermode InteractiveServer
@inject UsuarioUseCase usuario

<MudNavMenu>

    <MudNavLink Icon="@Icons.Material.Filled.Dashboard" Href="/">Tablero</MudNavLink>

    <AuthorizeView Roles="Administrador,Vendedor">
        <MudNavLink Icon="@Icons.Material.Filled.Sell" Href="/">Ventas</MudNavLink>
    </AuthorizeView>

    <AuthorizeView Roles="Bodeguero">
        <MudNavLink Icon="@Icons.Material.Filled.ShoppingCart" Href="/">Compras</MudNavLink>
    </AuthorizeView>

    @if (usuario.IsInRol("Administrador") || usuario.IsInRol("Bodeguero"))
    {
        <MudNavGroup Icon="@Icons.Material.Filled.Settings" Title="Configuración" Expanded="false">
            <AuthorizeView Roles="Administrador">
                <MudNavLink Icon="@Icons.Material.Filled.ManageAccounts" Href="/counter">Usuarios</MudNavLink>
            </AuthorizeView>
            <MudNavLink Icon="@Icons.Material.Filled.Business" Href="/">Proveedores</MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.Category" Href="/">Categorias</MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.Store" Href="/">Productos</MudNavLink>
        </MudNavGroup>
    }
    
</MudNavMenu>
