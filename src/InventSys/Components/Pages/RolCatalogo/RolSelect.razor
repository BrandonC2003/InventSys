@rendermode InteractiveServer
@inject RolCatalogoUseCase rolCatalogoUseCase

<MudSelect T="int" @bind-Value="Value" Label="@Label" Dense="true">
    @if (roles is null)
    {
        <MudSelectItem T="int" Disabled="true">Cargando...</MudSelectItem>
    }
    else
    {
        @foreach (var rol in roles)
        {
            <MudSelectItem T="int" Value="@rol.IdRol">@rol.Rol</MudSelectItem>
        }
    }
</MudSelect>

@code {
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = string.Empty;

    private List<RolCatalogo>? roles;

    protected override async Task OnInitializedAsync()
    {
        roles = await rolCatalogoUseCase.ObtenerRolesAsync();
    }
}