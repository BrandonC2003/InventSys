@page "/Usuario"
@attribute [Authorize(Roles = "Administrador")]

@inject IDialogService DialogService
@inject UsuarioUseCase usuarioUseCase
@inject RolCatalogoUseCase rolCatalogoUseCase
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Usuarios</MudText>

<MudTable Items="@Usuarios" Hover="true" Filter="new Func<Usuarios,bool>(FilterFunc1)" SortLabel="Ordenar Por"
          RowEditCommit="ActualizarUsuario" RowEditPreview="RespaldarUsuario" EditTrigger="TableEditTrigger.EditButton">
    <ToolBarContent>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AbrirNuevoUsuario">
            <MudIcon Icon="@Icons.Material.Filled.Add" /> Nuevo Usuario
        </MudButton>
        <MudSpacer />
        <MudTextField @bind-Value="searchString1" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Usuarios, object>(x=>x.Nombre)">
                UserName
            </MudTableSortLabel>
        </MudTh>
        <MudTh>Rol</MudTh>
        <MudTh>Nombre</MudTh>
        <MudTh>Apellido</MudTh>
        <MudTh>Correo</MudTh>
        <MudTh>Activo</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            @context.UserName
        </MudTd>
        <MudTd>
            @roles.Find(x => x.IdRol == @context.IdRol)?.Rol
        </MudTd>
        <MudTd>
            @context.Nombre
        </MudTd>
        <MudTd>
            @context.Apellido
        </MudTd>
        <MudTd>
            @context.CorreoElectronico
        </MudTd>
        <MudTd>
            @if (@context.Activo)
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"></MudIcon>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.DoNotDisturbAlt" Color="Color.Error"></MudIcon>
            }
        </MudTd>
    </RowTemplate>
    <RowEditingTemplate>
        <MudTd DataLabel="UserName">@context.UserName</MudTd>
        <MudTd DataLabel="Rol">
            <MudSelect T="int" @bind-Value="context.IdRol" Dense="true">
                @if (roles is null)
                {
                    <MudSelectItem T="int" Disabled="true">Cargando...</MudSelectItem>
                }
                else
                {
                    @foreach (var rol in roles)
                    {
                        <MudSelectItem T="int" Value="@rol.IdRol">@rol.Rol</MudSelectItem>
                    }
                }
            </MudSelect>
        </MudTd>
        <MudTd DataLabel="Nombre">
            <MudTextField @bind-Value="context.Nombre" Required />
        </MudTd>
        <MudTd DataLabel="Apellido">
            <MudTextField @bind-Value="context.Apellido" Required />
        </MudTd>
        <MudTd DataLabel="Correo">
            <MudTextField @bind-Value="context.CorreoElectronico" Required />
        </MudTd>
        <MudTd DataLabel="Activo">
            <MudSwitch @bind-Value="context.Activo" Color="Color.Success" UncheckedColor="Color.Error" />
        </MudTd>
    </RowEditingTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100}"
        RowsPerPageString="Filas por página:"
        HorizontalAlignment="HorizontalAlignment.Center"
        HidePageNumber="true" />
    </PagerContent>
    <EditButtonContent Context="button">
        <MudIconButton Color="Color.Primary"  Icon="@Icons.Material.Filled.Edit" OnClick="@button.ButtonAction" Disabled="@button.ButtonDisabled" />
    </EditButtonContent>
</MudTable>

@code {
    private List<Usuarios> usuariosInternos = new();

    private string searchString1 = "";

    private List<RolCatalogo>? roles;

    private Usuarios usuarioBackup = new();

    private readonly DialogOptions _maxWidth = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    //Carga de los usuarios desde la base de datos
    protected override async Task OnInitializedAsync()
    {
        usuariosInternos = await usuarioUseCase.ObtenerUsuariosAsync();
        roles = await rolCatalogoUseCase.ObtenerRolesAsync();
    }

    // Esto es lo que se mostrará en la tabla
    private IEnumerable<Usuarios> Usuarios => usuariosInternos;

    private async Task AbrirNuevoUsuario()
    {
        var dialog = await DialogService.ShowAsync<CrearUsuarioDialog>("Nuevo Usuario", _maxWidth);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Usuarios nuevo)
        {
            usuariosInternos.Add(nuevo);
        }
    }

    private void RespaldarUsuario(object usuario)
    {
        if(usuario is Usuarios usuarioRespaldo)
        {
            usuarioBackup = new Usuarios()
            {
                IdRol = usuarioRespaldo.IdRol,
                Nombre = usuarioRespaldo.Nombre,
                Apellido = usuarioRespaldo.Apellido,
                CorreoElectronico = usuarioRespaldo.CorreoElectronico,
                Activo = usuarioRespaldo.Activo,

            };
        }
    }

    private async void ActualizarUsuario(object usuario)
    {
        if (usuario is Usuarios usuarioActualizar)
        {
            if (UsuarioNecesitaActualizarse(usuarioActualizar))
            {
                try
                {
                    await usuarioUseCase.ActualizarUsuarioAsync(usuarioActualizar.IdUsuario, usuarioActualizar);
                    Snackbar.Add($"El usuario {usuarioActualizar.UserName} fue actualizado exitosamente", Severity.Success);
                }
                catch (Exception)
                {
                    Snackbar.Add($"Ocurrió un error al actualizar el usuario {usuarioActualizar.UserName}", Severity.Error);
                }

            }
        }
    }

    private bool UsuarioNecesitaActualizarse(Usuarios usuarioActualizar)
    {
        var necesitaActualizarse = usuarioBackup.IdRol != usuarioActualizar.IdRol ||
                                    usuarioBackup.Nombre != usuarioActualizar.Nombre ||
                                    usuarioBackup.Apellido != usuarioActualizar.Apellido ||
                                    usuarioBackup.CorreoElectronico != usuarioActualizar.CorreoElectronico ||
                                    usuarioBackup.Activo != usuarioActualizar.Activo;

        return necesitaActualizarse;
    }

    private void EliminarUsuario(Usuarios usuario)
    {
        usuariosInternos.Remove(usuario);
    }

    private bool FilterFunc1(Usuarios element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Usuarios element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.UserName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Nombre.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Apellido.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.CorreoElectronico.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }
}