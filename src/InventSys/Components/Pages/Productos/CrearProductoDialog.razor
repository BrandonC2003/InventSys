<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5">Nuevo producto</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@producto" OnValidSubmit="Submit" id="createProductoForm">
            <DataAnnotationsValidator />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
            }
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField Label="Producto" @bind-Value="producto.NombreProducto" For="@(() => producto.NombreProducto)" />
                </MudItem>
                <MudItem xs="12">
                    <MudAutocomplete
                    T="Categoria"
                    Label="Categoria"
                    @bind-Value="producto.Categoria"
                    For="@(() => producto.Categoria)"
                    ToStringFunc="categoria => categoria?.NombreCategoria"
                    SearchFunc="BuscarCategoria"
                    />
                </MudItem>
                <MudItem xs="12">
                    <MudAutocomplete T="Proveedor"
                    Label="Proveedor"
                    @bind-Value="producto.Proveedor"
                    For="@(() => producto.Proveedor)"
                    ToStringFunc="proveedor => proveedor?.NombreProveedor"
                    SearchFunc="BuscarProveedor" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Descripción" @bind-Value="producto.Descripcion" For="@(() => producto.Descripcion)" Lines="3"/>
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField Label="Precio de compra" @bind-Value="producto.PrecioCompra" For="@(() => producto.PrecioCompra)" Min="0.0" />
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField Label="Precio de venta" @bind-Value="producto.PrecioVenta" For="@(() => producto.PrecioVenta)" Min="0.0" />
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField Label="Stok" @bind-Value="producto.Stok" For="@(() => producto.Stok)" Min="0" />
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField Label="Stok bajo" @bind-Value="producto.StokBajo" For="@(() => producto.StokBajo)" Min="0" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Mensaje de alerta" @bind-Value="producto.MensajeAlerta" For="@(() => producto.MensajeAlerta)" Lines="3" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Filled" OnClick="Cancel" Color="Color.Secondary">Cancelar</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Form="createProductoForm">Crear producto</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Inject]
    private ProductoUseCase ProductoUseCase { get; set; }
    [Inject]
    private CategoriaUseCase CategoriaUseCase { get; set; }
    [Inject]
    private ProveedorUseCase ProveedorUseCase { get; set; }

    private List<Categoria> categorias = new();
    private List<Proveedor> proveedores = new();

    private ProductoDto producto = new();

    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        categorias = await CategoriaUseCase.ObtenerCategorias();
        proveedores = await ProveedorUseCase.ObtenerProveedores();
    }


    private async Task Submit()
    {
        errorMessage = string.Empty;
        try
        {
            var productoNuevo = new Producto()
            {
                NombreProducto = producto.NombreProducto,
                IdCategoria = producto.Categoria.IdCategoria,
                IdProveedor = producto.Proveedor.IdProveedor,
                Descripcion = producto.Descripcion,
                PrecioCompra = (decimal)producto.PrecioCompra,
                PrecioVenta = (decimal)producto.PrecioVenta,
                Stok = producto.Stok,
                StokBajo = producto.StokBajo,
                MensajeAlerta = producto.MensajeAlerta
            };

            var productoCreado = await ProductoUseCase.CrearProducto(productoNuevo);
            productoCreado.IdCategoriaNavigation = producto.Categoria;
            productoCreado.IdProveedorNavigation = producto.Proveedor;

            MudDialog.Close(DialogResult.Ok(productoCreado));
        }
        catch (CustomExeption ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception)
        {
            errorMessage = "Ocurrió un error al crear el producto";
        }

    }

    private void Cancel() => MudDialog.Cancel();

    private Task<IEnumerable<Categoria>> BuscarCategoria(string value,CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult((IEnumerable<Categoria>)categorias);
        }
        return Task.FromResult(categorias.Where(c => c.NombreCategoria.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private Task<IEnumerable<Proveedor>> BuscarProveedor(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult((IEnumerable<Proveedor>)proveedores);
        }
        return Task.FromResult(proveedores.Where(c => c.NombreProveedor.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

}